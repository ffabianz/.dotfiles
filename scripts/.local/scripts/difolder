#!/usr/bin/env bash

# dont ask why i have this, but is usefull for me

TARGET_DIR="${1:-.}"

if [ ! -d "$TARGET_DIR" ]; then
    echo "Error: '$TARGET_DIR' is not a valid directory."
    exit 1
fi

cd "$TARGET_DIR" || exit 1

for dir in */; do
    if [ -d "$dir" ]; then
        mv "$dir"* .
    fi
done
